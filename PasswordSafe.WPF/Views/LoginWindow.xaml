<Window x:Class="PasswordSafe.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в PasswordSafe" 
        Height="200" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Введите мастер-пароль:" 
                   FontSize="14"/>

        <PasswordBox Grid.Row="2" 
                     x:Name="PasswordBox"
                     FontSize="14"
                     Height="30"/>

        <Button Grid.Row="4" 
                Content="Войти" 
                Width="100"
                Height="35"
                Click="Login_Click"
                IsDefault="True"/>
    </Grid>
</Window>
