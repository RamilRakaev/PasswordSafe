<Window x:Class="PasswordSafe.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PasswordSafe" 
        Height="500" 
        Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: список записей -->
        <DockPanel Grid.Column="0" Margin="5">
            <StackPanel DockPanel.Dock="Top" 
                        Orientation="Horizontal" 
                        Margin="0,0,0,5">
                <Button Content="Добавить" 
                        Width="80" 
                        Margin="2"
                        Click="Add_Click"/>
                <Button Content="Удалить" 
                        Width="80" 
                        Margin="2"
                        Click="Delete_Click"/>
                <Button Content="Сменить пароль" 
                        Width="120" 
                        Margin="2"
                        Click="ChangePassword_Click"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Top" 
                        Orientation="Horizontal" 
                        Margin="0,0,0,5">
                <Button Content="Категории" Click="ManageCategories_Click" 
                    Width="80" Margin="2"/>
                <Button Content="Свернуть" Width="80" Margin="2" Click="CollapseAll_Click"/>
                <Button Content="Развернуть" Width="80" Margin="2" Click="ExpandAll_Click"/>
            </StackPanel>

            <ListBox x:Name="EntriesList"
                 DisplayMemberPath="Title"
                 SelectionChanged="EntriesList_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <Expander IsExpanded="True"
                                                  Expanded="Expander_Expanded"
                                                  Collapsed="Expander_Collapsed"
                                                  Background="#F5F5F5"
                                                  BorderBrush="#DDD"
                                                  BorderThickness="0,0,0,1"
                                                  Padding="2">
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"/>
                                                        <TextBlock Text=" ("
                                                       Foreground="Gray"/>
                                                        <TextBlock Text="{Binding ItemCount}"
                                                       Foreground="Gray"/>
                                                        <TextBlock Text=")"
                                                       Foreground="Gray"/>
                                                    </StackPanel>
                                                </Expander.Header>
                                                <ItemsPresenter/>
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListBox.GroupStyle>
            </ListBox>
            

        </DockPanel>

        <GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch"/>

        <!-- Правая панель: детали записи -->
        <ScrollViewer Grid.Column="2" Margin="5">
            <StackPanel x:Name="DetailsPanel" IsEnabled="False">
                <TextBlock Text="Название:" Margin="0,5,0,2"/>
                <TextBox x:Name="TitleBox"/>

                <TextBlock Text="Логин:" Margin="0,5,0,2"/>
                <TextBox x:Name="LoginBox"/>

                <TextBlock Text="Секрет:" Margin="0,5,0,2"/>
                <TextBox x:Name="SecretBox"/>

                <TextBlock Text="Категория:" Margin="0,5,0,2"/>
                <ComboBox x:Name="CategoryBox"
                    DisplayMemberPath="Name"
                    SelectedValuePath="Id"/>


                <TextBlock Text="Дополнительные данные:" 
                           Margin="0,10,0,2" 
                           FontWeight="Bold"/>
                <DataGrid x:Name="ExtrasGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          Height="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ключ" 
                                            Binding="{Binding Key}" 
                                            Width="*"/>
                        <DataGridTextColumn Header="Значение" 
                                            Binding="{Binding Value}" 
                                            Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Сохранить" 
                        Width="120" 
                        Height="35"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Click="Save_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
