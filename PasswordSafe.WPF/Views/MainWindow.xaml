<Window x:Class="PasswordSafe.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PasswordSafe" 
        Height="500" 
        Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: список записей -->
        <DockPanel Grid.Column="0" Margin="5">
            <StackPanel DockPanel.Dock="Top" 
                        Orientation="Horizontal" 
                        Margin="0,0,0,5">
                <Button Content="Добавить" 
                        Width="80" 
                        Margin="2"
                        Click="Add_Click"/>
                <Button Content="Удалить" 
                        Width="80" 
                        Margin="2"
                        Click="Delete_Click"/>
                <Button Content="Сменить пароль" 
                        Width="120" 
                        Margin="2"
                        Click="ChangePassword_Click"/>
            </StackPanel>

            <ListBox x:Name="EntriesList"
                     DisplayMemberPath="Title"
                     SelectionChanged="EntriesList_SelectionChanged"/>
        </DockPanel>

        <GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch"/>

        <!-- Правая панель: детали записи -->
        <ScrollViewer Grid.Column="2" Margin="5">
            <StackPanel x:Name="DetailsPanel" IsEnabled="False">
                <TextBlock Text="Название:" Margin="0,5,0,2"/>
                <TextBox x:Name="TitleBox"/>

                <TextBlock Text="Логин:" Margin="0,5,0,2"/>
                <TextBox x:Name="LoginBox"/>

                <TextBlock Text="Секрет:" Margin="0,5,0,2"/>
                <TextBox x:Name="SecretBox"/>

                <TextBlock Text="Дополнительные данные:" 
                           Margin="0,10,0,2" 
                           FontWeight="Bold"/>
                <DataGrid x:Name="ExtrasGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          Height="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ключ" 
                                            Binding="{Binding Key}" 
                                            Width="*"/>
                        <DataGridTextColumn Header="Значение" 
                                            Binding="{Binding Value}" 
                                            Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Сохранить" 
                        Width="120" 
                        Height="35"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Click="Save_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
