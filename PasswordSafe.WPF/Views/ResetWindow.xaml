<Window x:Class="PasswordSafe.WPF.Views.ResetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена мастер-пароля" 
        Height="320" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Старый пароль:" 
                   Margin="0,0,0,3"/>
        <PasswordBox Grid.Row="1" 
                     x:Name="OldPasswordBox" 
                     Height="28"/>

        <TextBlock Grid.Row="3" 
                   Text="Новый пароль:" 
                   Margin="0,0,0,3"/>
        <PasswordBox Grid.Row="4" 
                     x:Name="NewPasswordBox" 
                     Height="28"/>

        <TextBlock Grid.Row="6" 
                   Text="Повтор нового пароля:" 
                   Margin="0,0,0,3"/>
        <PasswordBox Grid.Row="7" 
                     x:Name="RepeatPasswordBox" 
                     Height="28"/>

        <StackPanel Grid.Row="9" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Отмена" 
                    Width="90" 
                    Height="32" 
                    Margin="0,0,8,0"
                    Click="Cancel_Click"
                    IsCancel="True"/>
            <Button Content="Сменить" 
                    Width="90" 
                    Height="32"
                    Click="Reset_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
